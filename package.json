{
  "name": "distributed-order-platform",
  "version": "1.0.0",
  "description": "Distributed Order & Fulfillment Platform",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate:order": "ts-node src/order/infrastructure/database/migrations/run.ts",
    "migrate:payment": "ts-node src/payment/infrastructure/database/migrations/run.ts",
    "migrate:inventory": "ts-node src/inventory/infrastructure/database/migrations/run.ts",
    "migrate:shipping": "ts-node src/shipping/infrastructure/database/migrations/run.ts",
    "migrate:notification": "ts-node src/notification/infrastructure/database/migrations/run.ts",
    "migrate:all": "npm run migrate:order && npm run migrate:payment && npm run migrate:inventory && npm run migrate:shipping && npm run migrate:notification",
    "temporal:worker": "ts-node src/shared/infrastructure/temporal/worker.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@temporalio/activity": "^1.9.0",
    "@temporalio/client": "^1.9.0",
    "@temporalio/worker": "^1.9.0",
    "@temporalio/workflow": "^1.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "kafkajs": "^2.2.4",
    "kysely": "^0.27.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
